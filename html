<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>AI Trading Terminal</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-white">

<div class="flex h-screen">

  <!-- SIDEBAR -->
  <div class="w-60 bg-gray-800 p-4">
    <h1 class="text-xl font-bold mb-6">AVE Claw</h1>
    <ul class="space-y-3">
      <li>🏠 Dashboard</li>
      <li>📊 Market</li>
      <li>🐋 Whale Tracker</li>
      <li>🤖 Auto Trade</li>
      <li>🏆 Leaderboard</li>
    </ul>
  </div>

  <!-- MAIN -->
  <div class="flex-1 p-6">

    <!-- TOP BAR -->
    <div class="flex justify-between mb-4">
      <h2 class="text-2xl font-bold">BTC/USDT</h2>
      <div id="price" class="text-green-400">Loading...</div>
    </div>

    <!-- CHART (Placeholder) -->
    <div class="bg-gray-800 h-64 flex items-center justify-center rounded-xl mb-4">
      Chart Area (Integrate TradingView nanti)
    </div>

    <!-- SIGNAL BOX -->
    <div class="bg-gray-800 p-4 rounded-xl mb-4">
      <h3 class="text-lg font-bold mb-2">AI Signal</h3>
      <div id="signal" class="text-2xl font-bold">WAIT</div>
      <div id="confidence" class="text-sm text-gray-400">Confidence: -</div>
    </div>

    <!-- EXECUTE BUTTON -->
    <button onclick="executeTrade()" 
      class="bg-green-500 px-4 py-2 rounded-xl">
      Execute Trade
    </button>

  </div>

</div>

<script>

// 🔄 GET PRICE (BINANCE)
async function getPrice() {
  const res = await fetch("https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT");
  const data = await res.json();
  document.getElementById("price").innerText = "$" + parseFloat(data.price).toFixed(2);
}

// 🤖 GET SIGNAL (BACKEND LU)
async function getSignal() {
  try {
    const res = await fetch("http://localhost:8000/signal");
    const data = await res.json();

    document.getElementById("signal").innerText = data.signal;
    document.getElementById("confidence").innerText = "Confidence: " + data.confidence;
  } catch {
    console.log("Backend belum jalan bro");
  }
}

// 🚀 EXECUTE TRADE
async function executeTrade() {
  await fetch("http://localhost:8000/execute");
  alert("Trade executed!");
}

// 🔁 AUTO REFRESH
setInterval(() => {
  getPrice();
  getSignal();
}, 3000);

</script>

</body>
</html>
